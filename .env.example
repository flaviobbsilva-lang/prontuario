# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Apenas para o seed local e scripts administrativos (NUNCA no cliente,
# NUNCA versionado, NUNCA na Vercel)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Criptografia de campo (nome, CPF, telefone, e-mail, história clínica,
# notas SOAP). Gere com: openssl rand -base64 32
# Guarde uma cópia em local seguro (gerenciador de senhas) fora deste
# arquivo: perder a chave torna os dados já gravados ilegíveis para sempre.
FIELD_ENCRYPTION_KEY=
